---
import { getDict, type Locale } from '../lib/i18n';
interface Props { lang: Locale }
const { lang } = Astro.props;
const t = getDict(lang);
const aiCaps: string[] = t.aiCaps || [];
---

<section id="ki" style="position:relative;max-width:980px;margin:128px auto 0;padding:0 24px;text-align:center;overflow:hidden">
  <div data-reveal style="position:relative;font-size:12.5px;font-weight:700;letter-spacing:0.22em;color:#b07bff">{t.ki_eyebrow}</div>
  <h2 data-reveal class="ct-h2" style="position:relative;margin-top:18px;font-size:46px;line-height:1.08;font-weight:600;letter-spacing:-0.03em;color:#f4f2f8">{t.ki_h2a}<br />{t.ki_h2b}</h2>
  <p data-reveal style="position:relative;max-width:580px;margin:20px auto 0;font-size:17.5px;line-height:1.6;color:#a6a2b2">{t.ki_p}</p>

  <div data-reveal class="ct-grid-ki" style="position:relative;margin-top:36px;display:grid;grid-template-columns:repeat(2,1fr);gap:14px;max-width:640px;margin-left:auto;margin-right:auto;text-align:left">
    <div style="background:linear-gradient(165deg,#221836,#16151b);box-shadow:0 1px 0 rgba(255,255,255,0.05) inset,0 16px 38px rgba(0,0,0,0.4);border:0.5px solid rgba(143,91,255,0.28);border-radius:16px;padding:22px 22px">
      <div style="display:flex;align-items:center;gap:9px"><span style="font-size:11px;font-weight:700;letter-spacing:.04em;color:#fff;background:linear-gradient(135deg,#9F55FF,#6E5CFF);padding:4px 10px;border-radius:999px">{t.ki_c1_badge}</span><span style="font-size:15px;font-weight:600;color:#f4f2f8">{t.ki_c1_title}</span></div>
      <p style="margin-top:11px;font-size:13.5px;line-height:1.6;color:#a6a2b2">{t.ki_c1_p}</p>
    </div>
    <div style="background:linear-gradient(165deg,#1a1a20,#151418);border:0.5px solid rgba(255,255,255,0.07);border-radius:16px;box-shadow:0 1px 0 rgba(255,255,255,0.04) inset,0 16px 38px rgba(0,0,0,0.4);padding:22px 22px">
      <div style="display:flex;align-items:center;gap:9px"><span style="font-size:11px;font-weight:700;letter-spacing:.04em;color:#cbb6ff;background:rgba(143,91,255,0.16);padding:4px 10px;border-radius:999px">{t.ki_c2_badge}</span><span style="font-size:15px;font-weight:600;color:#f4f2f8">{t.ki_c2_title}</span></div>
      <p style="margin-top:11px;font-size:13.5px;line-height:1.6;color:#a6a2b2">{t.ki_c2_p}</p>
    </div>
  </div>

  <div style="position:relative;margin-top:38px;display:flex;gap:10px;justify-content:center;flex-wrap:wrap">
    {aiCaps.map((cap) => (
      <span data-reveal style="display:inline-flex;align-items:center;gap:9px;white-space:nowrap;font-size:13.5px;font-weight:500;color:#e7e3f2;background:rgba(255,255,255,0.04);border:0.5px solid rgba(255,255,255,0.1);padding:10px 16px;border-radius:999px">
        <span aria-hidden="true" style="width:6px;height:6px;border-radius:999px;background:linear-gradient(135deg,#9F55FF,#6E5CFF)"></span>{cap}
      </span>
    ))}
  </div>
</section>
