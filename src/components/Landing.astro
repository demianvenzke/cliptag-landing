---
import Nav from './Nav.astro';
import Hero from './Hero.astro';
import Mockup from './Mockup.astro';
import Features from './Features.astro';
import HowItWorks from './HowItWorks.astro';
import AiSection from './AiSection.astro';
import Pricing from './Pricing.astro';
import Faq from './Faq.astro';
import CtaBand from './CtaBand.astro';
import Footer from './Footer.astro';
import { getDict, type Locale } from '../lib/i18n';

interface Props { lang: Locale }
const { lang } = Astro.props;
const t = getDict(lang);
---

<div style="min-height:100vh;background:radial-gradient(1100px 560px at 50% -12%,rgba(125,82,205,0.18),transparent 60%),linear-gradient(180deg,#1b1a22 0%,#16151d 32%,#100f15 68%,#08080b 100%);overflow-x:hidden">
  <Nav lang={lang} />
  <Hero lang={lang} />
  <Mockup lang={lang} />
  <Features lang={lang} />
  <HowItWorks lang={lang} />
  <AiSection lang={lang} />
  <Pricing lang={lang} />
  <Faq lang={lang} />
  <CtaBand lang={lang} />
  <Footer lang={lang} />

  <div id="ct-toast" role="status" aria-live="polite" data-preview={t.toast_text} data-soon={t.soon_text} style="position:fixed;left:50%;bottom:28px;transform:translateX(-50%) translateY(20px);z-index:120;display:flex;align-items:center;gap:10px;max-width:calc(100vw - 40px);font-size:13.5px;font-weight:500;color:#f4f2f8;background:rgba(20,20,23,0.92);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border:0.5px solid rgba(143,91,255,0.35);box-shadow:0 16px 44px rgba(0,0,0,0.55);padding:13px 18px;border-radius:13px;opacity:0;pointer-events:none;transition:opacity .3s ease,transform .35s cubic-bezier(.16,1,.3,1)">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false" style="flex:0 0 auto"><path d="M12 3v12m0 0l-5-5m5 5l5-5M5 21h14" stroke="#cbb6ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    <span id="ct-toast-text">{t.toast_text}</span>
  </div>
</div>

<style>
  #ct-toast[data-show]{opacity:1 !important;transform:translateX(-50%) translateY(0) !important}
</style>

<script>
  import '../scripts/client.ts';
</script>
