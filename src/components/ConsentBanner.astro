---
import { getDict, type Locale } from '../lib/i18n';
interface Props { lang: Locale }
const { lang } = Astro.props;
const t = getDict(lang);
---

<div id="ct-consent" role="dialog" aria-label="Cookies" aria-live="polite"
  style="display:none;position:fixed;left:18px;right:18px;bottom:18px;z-index:95;max-width:520px;margin:0 auto;flex-wrap:wrap;align-items:center;gap:14px;background:rgba(20,19,26,0.97);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border:0.5px solid rgba(255,255,255,0.12);box-shadow:0 18px 50px rgba(0,0,0,0.6);border-radius:14px;padding:16px 18px">
  <span style="flex:1;min-width:200px;font-size:13px;line-height:1.55;color:#cdc9d8">
    {t.consent_text} <a href="/privacy" style="color:#cbb6ff;font-weight:500;white-space:nowrap">{t.consent_more}</a>
  </span>
  <div style="display:flex;gap:8px;margin-left:auto">
    <button id="ct-consent-decline" type="button" style="font-size:13px;font-weight:500;color:#cdc9d8;background:rgba(255,255,255,0.06);border:0.5px solid rgba(255,255,255,0.12);padding:9px 14px;border-radius:9px;cursor:pointer">{t.consent_decline}</button>
    <button id="ct-consent-accept" type="button" style="font-size:13px;font-weight:600;color:#fff;background:linear-gradient(135deg,#9F55FF,#6E5CFF);border:0;padding:9px 16px;border-radius:9px;cursor:pointer;box-shadow:0 6px 16px rgba(120,80,240,0.4)">{t.consent_accept}</button>
  </div>
</div>

<script>
  (() => {
    const el = document.getElementById('ct-consent');
    if (!el) return;
    let saved: string | null = null;
    try { saved = localStorage.getItem('ct_consent'); } catch {}
    // Only PROMPT visitors likely in the EEA/UK/CH — everywhere else consent is granted
    // by default (see Base.astro) so no banner is needed. Timezone heuristic: privacy-
    // friendly (no IP lookup, no third party). IMPORTANT: this only decides whether the
    // opt-in banner SHOWS; the real consent gate is Google's IP-based region default, so a
    // wrong timezone can never cause non-compliant tracking (worst case: a mislocated EEA
    // user can't opt in and simply stays denied). Europe/* covers all mainland EEA/UK/CH;
    // the extras catch IS/CY/PT-islands/ES-Canary+Ceuta which live outside the Europe/ prefix.
    const inConsentRegion = () => {
      try {
        const tz = Intl.DateTimeFormat().resolvedOptions().timeZone || '';
        if (tz.indexOf('Europe/') === 0) return true;
        return ['Atlantic/Reykjavik', 'Atlantic/Azores', 'Atlantic/Madeira', 'Atlantic/Canary', 'Asia/Nicosia', 'Asia/Famagusta', 'Africa/Ceuta'].indexOf(tz) !== -1;
      } catch { return true; } // detection failed → show the banner (safe default)
    };
    // NOTE: toggle via style.display, not the `hidden` attribute — the element's
    // inline `display` would override `[hidden]{display:none}` and never hide it.
    if (!saved && inConsentRegion()) el.style.display = 'flex';
    const GRANT = { ad_storage: 'granted', ad_user_data: 'granted', ad_personalization: 'granted', analytics_storage: 'granted' };
    const DENY  = { ad_storage: 'denied',  ad_user_data: 'denied',  ad_personalization: 'denied',  analytics_storage: 'denied' };
    const close = (v: string) => {
      try { localStorage.setItem('ct_consent', v); } catch {}
      el.style.display = 'none';
      const g = (window as any).gtag;
      // Consent Mode v2: signal the full choice in BOTH directions. Decline → denied also
      // overrides the geo "granted-by-default" that applies outside the EEA/UK/CH.
      if (typeof g === 'function') g('consent', 'update', v === 'granted' ? GRANT : DENY);
      if (v === 'granted') {
        // PostHog is injected only now (on opt-in), never before — see Base.astro.
        try { (window as any).__ctLoadPostHog?.(); } catch {}
      }
    };
    document.getElementById('ct-consent-accept')?.addEventListener('click', () => close('granted'));
    document.getElementById('ct-consent-decline')?.addEventListener('click', () => close('denied'));
  })();
</script>
