---
import { LINKS } from '../config/site';
import { getDict, type Locale } from '../lib/i18n';

interface Props { lang: Locale }
const { lang } = Astro.props;
const t = getDict(lang);
---

<header id="top" style="position:relative;max-width:1120px;margin:0 auto;padding:84px 24px 0;text-align:center">
  <div aria-hidden="true" style="position:absolute;top:-20px;left:50%;transform:translateX(-50%);width:1100px;max-width:120vw;height:520px;pointer-events:none;z-index:-1">
    <div style="position:absolute;top:30px;left:14%;width:340px;height:340px;border-radius:50%;background:radial-gradient(circle,rgba(143,91,255,0.20),transparent 64%);animation:ct-aurora1 15s ease-in-out infinite"></div>
    <div style="position:absolute;top:70px;right:13%;width:300px;height:300px;border-radius:50%;background:radial-gradient(circle,rgba(110,92,255,0.17),transparent 64%);animation:ct-aurora2 18s ease-in-out infinite"></div>
  </div>

  <h1 data-reveal class="ct-h1" style="margin-top:0;font-size:68px;line-height:1.02;font-weight:600;letter-spacing:-0.035em;color:#f4f2f8">
    {t.hero_title1}<br />
    <span style="background:linear-gradient(110deg,#b07bff,#6E5CFF,#b07bff);background-size:200% 100%;-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;animation:ct-shimmer 7s linear infinite">{t.hero_title2}</span>
  </h1>

  <p data-reveal style="max-width:560px;margin:24px auto 0;font-size:19px;line-height:1.6;color:#a6a2b2">
    {t.hero_sub_pre} <span style="font-family:ui-monospace,Menlo,monospace;font-size:16px;color:#cbb6ff">DJI_0042.MP4</span>{t.hero_sub_post}
  </p>

  <div data-reveal style="margin-top:34px;display:flex;gap:13px;justify-content:center;flex-wrap:wrap">
    <a href={LINKS.download} class="ct-cta" style="font-size:15px;color:#fff;font-weight:600;padding:14px 26px;border-radius:12px;background:linear-gradient(135deg,#9F55FF,#6E5CFF);box-shadow:0 8px 26px rgba(120,80,240,0.45);display:flex;align-items:center;gap:9px;white-space:nowrap">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false"><path d="M12 3v12m0 0l-5-5m5 5l5-5M5 21h14" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      {t.hero_cta_primary}
    </a>
    <a href="#features" class="ct-cta-ghost" style="font-size:15px;color:#cdc9d8;font-weight:500;padding:14px 24px;border-radius:12px;background:rgba(255,255,255,0.035);border:0.5px solid rgba(255,255,255,0.09);white-space:nowrap">{t.hero_cta_secondary}</a>
  </div>

  <p data-reveal style="margin-top:18px;font-size:13px;color:#8b8694">{t.hero_fineprint}</p>
</header>
