---
import { SITE } from '../config/site';
import { getDict, type Locale } from '../lib/i18n';
interface Props { lang: Locale }
const { lang } = Astro.props;
const t = getDict(lang);
---

<footer style="margin-top:110px;border-top:0.5px solid rgba(255,255,255,0.07)">
  <div style="max-width:1120px;margin:0 auto;padding:30px 24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px">
    <div style="display:flex;align-items:center;gap:10px">
      <img src="/cliptag-logo-dark.svg" alt="Cliptag" width="77" height="18" style="height:18px;width:auto;display:block;opacity:.92" />
      <span style="font-size:13.5px;color:#8b8694">© 2026 {SITE.company}</span>
    </div>
    <div style="display:flex;align-items:center;gap:24px;font-size:13.5px;color:#a6a2b2">
      <a class="ct-flink" href="/imprint">{t.footer_imprint}</a>
      <a class="ct-flink" href="/privacy">{t.footer_privacy}</a>
      <a class="ct-flink" href="/terms">{t.footer_terms}</a>
      <a class="ct-flink" href="/terms#refunds">{t.footer_refunds}</a>
      <a class="ct-flink" href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a>
    </div>
  </div>
</footer>

<style>
  .ct-flink{transition:color .2s}
  .ct-flink:hover{color:#f4f2f8}
</style>
