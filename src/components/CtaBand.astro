---
import { LINKS } from '../config/site';
import { getDict, type Locale } from '../lib/i18n';
interface Props { lang: Locale }
const { lang } = Astro.props;
const t = getDict(lang);
---

<section style="max-width:1120px;margin:118px auto 0;padding:0 24px">
  <div data-reveal style="position:relative;overflow:hidden;border-radius:26px;background:linear-gradient(135deg,#1a1330,#120f1a);border:0.5px solid rgba(143,91,255,0.2);padding:74px 32px;text-align:center">
    <div aria-hidden="true" style="position:absolute;bottom:-140px;left:50%;transform:translateX(-50%);width:720px;height:360px;background:radial-gradient(circle,rgba(143,91,255,0.2),transparent 68%);pointer-events:none"></div>
    <h2 class="ct-h2" style="position:relative;font-size:46px;line-height:1.08;font-weight:600;letter-spacing:-0.03em;color:#f4f2f8">{t.cta_h2}</h2>
    <p style="position:relative;margin-top:16px;font-size:18px;color:#a6a2b2">{t.cta_p}</p>
    <div style="position:relative;margin-top:30px;display:flex;justify-content:center">
      <a href={LINKS.download} class="ct-cta" style="font-size:15px;color:#fff;font-weight:600;padding:15px 30px;border-radius:12px;background:linear-gradient(135deg,#9F55FF,#6E5CFF);box-shadow:0 10px 30px rgba(120,80,240,0.5);display:inline-flex;align-items:center;gap:9px">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false"><path d="M12 3v12m0 0l-5-5m5 5l5-5M5 21h14" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        {t.hero_cta_primary}
      </a>
    </div>
    <p style="position:relative;margin-top:18px;font-size:13px;color:#8b8694">{t.hero_fineprint}</p>
  </div>
</section>
