---
import { getDict, type Locale } from '../lib/i18n';
interface Props { lang: Locale }
const { lang } = Astro.props;
const t = getDict(lang);
const steps: { title: string; body: string }[] = t.steps || [];
const s0 = steps[0] || { title: '', body: '' };
const s1 = steps[1] || { title: '', body: '' };
const s2 = steps[2] || { title: '', body: '' };
---

<section id="how" style="max-width:1120px;margin:118px auto 0;padding:0 24px">
  <div data-reveal style="text-align:center;margin-bottom:52px">
    <h2 class="ct-h2" style="font-size:44px;font-weight:600;letter-spacing:-0.03em;color:#f4f2f8">{t.how_h2}</h2>
  </div>
  <div class="ct-grid-how" style="display:grid;grid-template-columns:repeat(3,1fr);gap:56px;margin-bottom:40px">

    <div data-reveal>
      <div aria-hidden="true" style="height:96px;display:flex;align-items:center;color:#c4abff">
        <svg width="92" height="92" viewBox="0 0 56 56" fill="none">
          <defs>
            <linearGradient id="i1a" x1="10" y1="20" x2="46" y2="40" gradientUnits="userSpaceOnUse"><stop stop-color="#7d4be0"/><stop offset="1" stop-color="#4b3aa8"/></linearGradient>
            <linearGradient id="i1b" x1="10" y1="14" x2="46" y2="34" gradientUnits="userSpaceOnUse"><stop stop-color="#9F55FF"/><stop offset="1" stop-color="#6E5CFF"/></linearGradient>
            <linearGradient id="i1c" x1="10" y1="6" x2="46" y2="26" gradientUnits="userSpaceOnUse"><stop stop-color="#c78bff"/><stop offset=".55" stop-color="#9b6cff"/><stop offset="1" stop-color="#ff9d7a"/></linearGradient>
          </defs>
          <path d="M28 30L46 39L28 48L10 39Z" fill="url(#i1a)" opacity=".7"/>
          <path d="M28 23L46 32L28 41L10 32Z" fill="url(#i1b)" opacity=".9"/>
          <path d="M28 14L46 23L28 32L10 23Z" fill="url(#i1c)" style="transform-origin:28px 23px;animation:ct-bob 2.6s ease-in-out infinite"/>
        </svg>
      </div>
      <h3 style="margin-top:18px;font-size:18px;font-weight:600;color:#f4f2f8">{s0.title}</h3>
      <p style="margin-top:7px;font-size:14.5px;line-height:1.6;color:#a6a2b2">{s0.body}</p>
    </div>

    <div data-reveal>
      <div aria-hidden="true" style="height:96px;display:flex;align-items:center;color:#c4abff">
        <svg width="92" height="92" viewBox="0 0 56 56" fill="none">
          <defs>
            <linearGradient id="i2a" x1="14" y1="8" x2="42" y2="48" gradientUnits="userSpaceOnUse"><stop stop-color="#c78bff"/><stop offset=".5" stop-color="#9F55FF"/><stop offset="1" stop-color="#ff9d7a"/></linearGradient>
            <linearGradient id="i2b" x1="36" y1="30" x2="50" y2="48" gradientUnits="userSpaceOnUse"><stop stop-color="#e3a8ff"/><stop offset="1" stop-color="#9F55FF"/></linearGradient>
          </defs>
          <path d="M28 5 Q30 26 51 28 Q30 30 28 51 Q26 30 5 28 Q26 26 28 5 Z" fill="url(#i2a)" style="transform-origin:28px 28px;animation:ct-breathe 3s ease-in-out infinite"/>
          <path d="M44 35 Q45 40.5 50.5 41.5 Q45 42.5 44 48 Q43 42.5 37.5 41.5 Q43 40.5 44 35 Z" fill="url(#i2b)" style="transform-origin:44px 41.5px;animation:ct-twinkle 2.4s ease-in-out infinite .6s"/>
        </svg>
      </div>
      <h3 style="margin-top:18px;font-size:18px;font-weight:600;color:#f4f2f8">{s1.title}</h3>
      <p style="margin-top:7px;font-size:14.5px;line-height:1.6;color:#a6a2b2">{s1.body}</p>
    </div>

    <div data-reveal>
      <div aria-hidden="true" style="height:96px;display:flex;align-items:center;color:#c4abff">
        <svg width="92" height="92" viewBox="0 0 56 56" fill="none">
          <defs><linearGradient id="i3a" x1="10" y1="8" x2="46" y2="48" gradientUnits="userSpaceOnUse"><stop stop-color="#c78bff"/><stop offset=".5" stop-color="#9F55FF"/><stop offset="1" stop-color="#6E5CFF"/></linearGradient></defs>
          <g style="transform-origin:28px 28px;animation:ct-breathe 3s ease-in-out infinite">
            <circle cx="28" cy="28" r="20" fill="url(#i3a)"/>
            <path d="M19 28.5l6 6 12-13" stroke="#fff" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round"/>
          </g>
        </svg>
      </div>
      <h3 style="margin-top:18px;font-size:18px;font-weight:600;color:#f4f2f8">{s2.title}</h3>
      <p style="margin-top:7px;font-size:14.5px;line-height:1.6;color:#a6a2b2">{s2.body}</p>
    </div>

  </div>
</section>
