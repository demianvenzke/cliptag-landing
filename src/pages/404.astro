---
import Base from '../layouts/Base.astro';
---

<Base lang="en" path="" title="Page not found — Cliptag" description="The page you were looking for doesn't exist." localized={false}>
  <div style="min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:40px;background:radial-gradient(1100px 560px at 50% -12%,rgba(125,82,205,0.18),transparent 60%),linear-gradient(180deg,#1b1a22 0%,#100f15 60%,#08080b 100%)">
    <a href="/" aria-label="Cliptag — home"><img src="/cliptag-logo-dark.svg" alt="Cliptag" width="120" height="28" style="height:28px;width:auto" /></a>
    <h1 style="margin-top:40px;font-size:88px;font-weight:600;letter-spacing:-0.04em;background:linear-gradient(110deg,#b07bff,#6E5CFF,#b07bff);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent">404</h1>
    <p style="margin-top:8px;font-size:18px;color:#a6a2b2">This page doesn't exist.</p>
    <a href="/" class="ct-cta" style="margin-top:28px;font-size:15px;color:#fff;font-weight:600;padding:13px 24px;border-radius:12px;background:linear-gradient(135deg,#9F55FF,#6E5CFF);box-shadow:0 8px 26px rgba(120,80,240,0.45)">Back to home</a>
  </div>
</Base>
