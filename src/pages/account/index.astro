---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../config/site';
/* Account dashboard (EN v1). Localization (×6) + component split are a follow-up.
   noindex is enforced server-side via X-Robots-Tag for /account (see deploy/nginx-cliptag.conf). */
---

<Base lang="en" path="account" title={`Account — ${SITE.name}`} description="Manage your Cliptag plan, usage and license key." localized={false} noindex={true}>
  <section style="max-width:560px;margin:120px auto 80px;padding:0 24px;min-height:50vh">

    <!-- loading -->
    <div id="acct-loading" style="text-align:center;color:#a6a2b2;font-size:15px;padding:40px 0">Loading…</div>

    <!-- login -->
    <div id="acct-login" style="display:none">
      <h1 style="font-size:30px;font-weight:600;letter-spacing:-0.02em;color:#f4f2f8;text-align:center">Sign in</h1>
      <p style="margin-top:10px;font-size:15px;line-height:1.6;color:#a6a2b2;text-align:center">Enter the email you used at checkout. We'll send you a one-time sign-in link — no password needed.</p>
      <form id="acct-login-form" novalidate style="margin-top:24px">
        <div style="display:flex;gap:8px">
          <input id="acct-login-email" type="email" required placeholder="you@example.com" autocomplete="email"
            style="flex:1;min-width:0;font-size:14px;color:#f4f2f8;background:rgba(255,255,255,0.05);border:0.5px solid rgba(255,255,255,0.12);border-radius:10px;padding:13px 14px;outline:none" />
          <button type="submit" class="ct-cta"
            style="flex:0 0 auto;font-size:14px;font-weight:600;color:#fff;border:0;border-radius:10px;padding:13px 20px;background:linear-gradient(135deg,#9F55FF,#6E5CFF);box-shadow:0 6px 18px rgba(120,80,240,0.4);cursor:pointer;white-space:nowrap">Send link</button>
        </div>
        <p id="acct-login-err" role="status" aria-live="polite" style="margin-top:12px;font-size:13.5px;color:#ff8a8a;min-height:1px"></p>
      </form>
    </div>

    <!-- sent -->
    <div id="acct-sent" style="display:none;text-align:center">
      <div style="width:52px;height:52px;margin:0 auto 16px;border-radius:14px;background:linear-gradient(135deg,#9F55FF,#6E5CFF);display:flex;align-items:center;justify-content:center;box-shadow:0 8px 22px rgba(120,80,240,0.4)">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 6h16v12H4z" stroke="#fff" stroke-width="1.7" stroke-linejoin="round"/><path d="M4 7l8 6 8-6" stroke="#fff" stroke-width="1.7" stroke-linejoin="round"/></svg>
      </div>
      <h1 style="font-size:26px;font-weight:600;letter-spacing:-0.02em;color:#f4f2f8">Check your email</h1>
      <p style="margin-top:10px;font-size:15px;line-height:1.6;color:#a6a2b2">We sent a sign-in link to <strong id="acct-sent-email" style="color:#f4f2f8"></strong>. Open it on this device to continue.</p>
    </div>

    <!-- dashboard -->
    <div id="acct-dash" style="display:none">
      <div style="display:flex;align-items:baseline;justify-content:space-between;gap:12px;flex-wrap:wrap">
        <h1 style="font-size:26px;font-weight:600;letter-spacing:-0.02em;color:#f4f2f8">Your account</h1>
        <button id="acct-logout" style="font-size:13px;color:#a6a2b2;background:none;border:0;cursor:pointer;padding:4px">Sign out</button>
      </div>
      <p style="margin-top:4px;font-size:14px;color:#8b8694" id="acct-email"></p>

      <!-- has license -->
      <div id="acct-haslic" style="display:none;margin-top:24px">
        <div style="background:linear-gradient(168deg,#1c1c23,#161519);border:0.5px solid rgba(255,255,255,0.07);border-radius:16px;padding:24px">
          <div style="display:flex;align-items:center;justify-content:space-between;gap:10px">
            <div><div style="font-size:12px;color:#8b8694;text-transform:uppercase;letter-spacing:0.04em">Plan</div>
              <div id="acct-plan" style="font-size:22px;font-weight:600;color:#f4f2f8;margin-top:2px">—</div></div>
            <span id="acct-reset" style="font-size:12.5px;color:#8b8694"></span>
          </div>
          <div style="margin-top:18px">
            <div id="acct-usage-txt" style="font-size:13.5px;color:#a6a2b2"></div>
            <div style="margin-top:8px;height:8px;border-radius:999px;background:rgba(255,255,255,0.08);overflow:hidden">
              <div id="acct-usage-bar" style="height:100%;width:0%;border-radius:999px;background:linear-gradient(90deg,#9F55FF,#6E5CFF);transition:width .4s"></div>
            </div>
            <div id="acct-rollover" style="margin-top:8px;font-size:12.5px;color:#8b8694"></div>
          </div>
        </div>

        <div style="margin-top:14px;background:linear-gradient(168deg,#1c1c23,#161519);border:0.5px solid rgba(255,255,255,0.07);border-radius:16px;padding:24px">
          <div style="font-size:12px;color:#8b8694;text-transform:uppercase;letter-spacing:0.04em">License key</div>
          <div style="margin-top:8px;display:flex;align-items:center;gap:8px">
            <code id="acct-key" style="flex:1;min-width:0;font-size:15px;color:#f4f2f8;background:rgba(255,255,255,0.05);border:0.5px solid rgba(255,255,255,0.1);border-radius:9px;padding:10px 12px;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;overflow:auto;white-space:nowrap">—</code>
            <button id="acct-key-copy" style="flex:0 0 auto;font-size:13px;color:#f4f2f8;background:#1c1c21;border:0.5px solid rgba(255,255,255,0.1);border-radius:9px;padding:10px 14px;cursor:pointer">Copy</button>
          </div>
          <p style="margin-top:10px;font-size:12.5px;color:#8b8694">Paste this into Cliptag → Profile → License to unlock your plan on a device.</p>
        </div>

        <div style="margin-top:18px;display:flex;align-items:center;gap:14px;flex-wrap:wrap">
          <button id="acct-portal" class="ct-cta-ghost" style="font-size:14px;font-weight:500;color:#f4f2f8;background:#1c1c21;border:0.5px solid rgba(255,255,255,0.12);border-radius:10px;padding:11px 18px;cursor:pointer">Manage billing</button>
          <span id="acct-portal-msg" role="status" aria-live="polite" style="font-size:13px;color:#a6a2b2"></span>
        </div>
      </div>

      <!-- no license for this email -->
      <div id="acct-nolic" style="display:none;margin-top:24px;background:linear-gradient(168deg,#1c1c23,#161519);border:0.5px solid rgba(255,255,255,0.07);border-radius:16px;padding:24px;font-size:14.5px;line-height:1.6;color:#a6a2b2">
        No active plan is linked to this email yet. If you just purchased, it can take a moment to appear — refresh in a minute. Otherwise, <a href="/#pricing" style="color:#cbb6ff">choose a plan</a>. The free tier needs no account.
      </div>

      <!-- get the app (always visible when signed in) -->
      <div style="margin-top:14px;background:linear-gradient(168deg,#1c1c23,#161519);border:0.5px solid rgba(255,255,255,0.07);border-radius:16px;padding:24px;display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap">
        <div>
          <div style="font-size:15px;font-weight:600;color:#f4f2f8">Cliptag for Mac</div>
          <div style="margin-top:3px;font-size:12.5px;color:#8b8694">Latest version {SITE.appVersion} · Apple Silicon &amp; Intel</div>
        </div>
        <a href={SITE.appDownloadUrl} class="ct-cta" style="font-size:14px;font-weight:600;color:#fff;border-radius:10px;padding:11px 18px;background:linear-gradient(135deg,#9F55FF,#6E5CFF);box-shadow:0 6px 18px rgba(120,80,240,0.4);white-space:nowrap">Download</a>
      </div>

      <p style="margin-top:18px;text-align:center;font-size:12.5px;color:#8b8694">Need help? <a href={`mailto:${SITE.contactEmail}`} style="color:#cbb6ff">{SITE.contactEmail}</a></p>
    </div>

  </section>
  <script>import '../../scripts/account.ts';</script>
</Base>
